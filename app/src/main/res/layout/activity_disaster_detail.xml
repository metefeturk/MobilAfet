<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activities.DisasterDetailActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/title_disaster_detail" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding_horizontal"
            android:paddingTop="@dimen/screen_padding_vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_disaster_detail"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_spacing"
                android:text="@string/section_disaster_fields"
                android:textAppearance="@style/TextAppearance.Material3.TitleSmall" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_spacing"
                android:text="@string/label_disaster_type"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:id="@+id/value_disaster_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="24dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_spacing"
                android:text="@string/label_severity"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:id="@+id/value_severity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="24dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_spacing"
                android:text="@string/label_location"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:id="@+id/value_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="24dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_spacing"
                android:text="@string/label_time"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:id="@+id/value_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="24dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/block_spacing"
                android:text="@string/label_description"
                android:textAppearance="@style/TextAppearance.Material3.LabelLarge" />

            <TextView
                android:id="@+id/value_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:minHeight="48dp"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
